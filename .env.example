# PostgreSQL / Supabase connection string
# Format: postgresql://user:password@host:5432/dbname
# For Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-ref.supabase.co:5432/postgres

# Telegram API credentials (from https://my.telegram.org/apps)
# Required for telegram_api fetcher
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Optional: phone for interactive auth session (first run only)
TELEGRAM_PHONE=

# YouTube Data API (for metadata; transcripts don't require API key)
YOUTUBE_API_KEY=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
